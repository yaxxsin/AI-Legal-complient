generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

model User {
  id                  String                @id @default(uuid()) @db.Uuid
  email               String                @unique @db.VarChar(255)
  fullName            String                @map("full_name") @db.VarChar(100)
  phone               String?               @db.VarChar(20)
  avatarUrl           String?               @map("avatar_url") @db.VarChar(500)
  passwordHash        String?               @map("password_hash") @db.VarChar(100)
  role                String                @default("user") @db.VarChar(20)
  plan                String                @default("free") @db.VarChar(20)
  emailVerified       Boolean               @default(false) @map("email_verified")
  onboardingCompleted Boolean               @default(false) @map("onboarding_completed")
  lastLoginAt         DateTime?             @map("last_login_at")
  createdAt           DateTime              @default(now()) @map("created_at")
  updatedAt           DateTime              @default(now()) @updatedAt @map("updated_at")
  businessProfiles    BusinessProfile[]
  auditLogs           ComplianceItemAudit[]
  conversations       Conversation[]
  documentReviews     DocumentReview[]
  generatedDocuments  GeneratedDocument[]
  invoices            Invoice[]
  notifications       Notification[]
  sessions            Session[]
  subscription        Subscription?
  sentInvitations     TeamInvitation[]      @relation("TeamInviter")
  teamMemberships     TeamMember[]
  ownedTeams          Team[]                @relation("TeamOwner")

  @@map("users")
}

model Session {
  id           String   @id @default(uuid()) @db.Uuid
  userId       String   @map("user_id") @db.Uuid
  refreshToken String   @unique @map("refresh_token") @db.VarChar(500)
  ipAddress    String?  @map("ip_address") @db.VarChar(45)
  userAgent    String?  @map("user_agent") @db.VarChar(500)
  deviceName   String?  @map("device_name") @db.VarChar(100)
  isActive     Boolean  @default(true) @map("is_active")
  lastActiveAt DateTime @default(now()) @map("last_active_at")
  expiresAt    DateTime @map("expires_at")
  createdAt    DateTime @default(now()) @map("created_at")
  user         User     @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId])
  @@index([refreshToken])
  @@index([expiresAt])
  @@map("sessions")
}

model BusinessProfile {
  id                 String                   @id @default(uuid()) @db.Uuid
  userId             String                   @map("user_id") @db.Uuid
  businessName       String                   @map("business_name") @db.VarChar(200)
  entityType         String                   @map("entity_type") @db.VarChar(50)
  establishmentDate  DateTime?                @map("establishment_date") @db.Date
  sectorId           String?                  @map("sector_id") @db.Uuid
  subSectorIds       Json?                    @map("sub_sector_ids")
  employeeCount      Int                      @default(0) @map("employee_count")
  annualRevenue      String?                  @map("annual_revenue") @db.VarChar(50)
  city               String?                  @db.VarChar(100)
  province           String?                  @db.VarChar(100)
  hasNib             Boolean                  @default(false) @map("has_nib")
  nibNumber          String?                  @map("nib_number") @db.VarChar(50)
  npwp               String?                  @db.VarChar(50)
  isOnlineBusiness   Boolean                  @default(false) @map("is_online_business")
  onboardingStep     Int                      @default(1) @map("onboarding_step")
  isDraft            Boolean                  @default(true) @map("is_draft")
  createdAt          DateTime                 @default(now()) @map("created_at")
  updatedAt          DateTime                 @default(now()) @updatedAt @map("updated_at")
  kbliCodes          Json?                    @map("kbli_codes")
  kbliDescriptions   Json?                    @map("kbli_descriptions")
  sector             Sector?                  @relation(fields: [sectorId], references: [id])
  user               User                     @relation(fields: [userId], references: [id], onDelete: Cascade)
  complianceItems    ComplianceItem[]
  scoreHistory       ComplianceScoreHistory[]
  conversations      Conversation[]
  generatedDocuments GeneratedDocument[]
  ossRegistration    OssRegistration?

  @@map("business_profiles")
}

model Sector {
  id               String            @id @default(uuid()) @db.Uuid
  name             String            @db.VarChar(200)
  code             String?           @db.VarChar(10)
  parentId         String?           @map("parent_id") @db.Uuid
  icon             String?           @db.VarChar(50)
  isActive         Boolean           @default(true) @map("is_active")
  createdAt        DateTime          @default(now()) @map("created_at")
  businessProfiles BusinessProfile[]
  parent           Sector?           @relation("SectorHierarchy", fields: [parentId], references: [id])
  children         Sector[]          @relation("SectorHierarchy")

  @@map("sectors")
}

model ComplianceCategory {
  id        String           @id @default(uuid()) @db.Uuid
  name      String           @db.VarChar(100)
  icon      String?          @db.VarChar(50)
  sortOrder Int              @default(0) @map("sort_order")
  createdAt DateTime         @default(now()) @map("created_at")
  items     ComplianceItem[]
  rules     ComplianceRule[]

  @@map("compliance_categories")
}

model ComplianceRule {
  id              String             @id @default(uuid()) @db.Uuid
  title           String             @db.VarChar(300)
  description     String
  categoryId      String             @map("category_id") @db.Uuid
  priority        String             @db.VarChar(20)
  conditions      Json
  legalReferences Json               @map("legal_references")
  dueDateLogic    Json?              @map("due_date_logic")
  guidanceText    String?            @map("guidance_text")
  isPublished     Boolean            @default(true) @map("is_published")
  effectiveFrom   DateTime?          @map("effective_from") @db.Date
  createdAt       DateTime           @default(now()) @map("created_at")
  updatedAt       DateTime           @default(now()) @updatedAt @map("updated_at")
  complianceItems ComplianceItem[]
  category        ComplianceCategory @relation(fields: [categoryId], references: [id])

  @@map("compliance_rules")
}

model ComplianceItem {
  id                String                @id @default(uuid()) @db.Uuid
  businessProfileId String                @map("business_profile_id") @db.Uuid
  ruleId            String                @map("rule_id") @db.Uuid
  categoryId        String                @map("category_id") @db.Uuid
  title             String                @db.VarChar(300)
  description       String
  legalBasis        Json                  @map("legal_basis")
  priority          String                @db.VarChar(20)
  status            String                @default("pending") @db.VarChar(20)
  dueDate           DateTime?             @map("due_date") @db.Date
  completedAt       DateTime?             @map("completed_at")
  evidenceUrl       String?               @map("evidence_url") @db.VarChar(500)
  notes             String?
  createdAt         DateTime              @default(now()) @map("created_at")
  updatedAt         DateTime              @default(now()) @updatedAt @map("updated_at")
  auditLogs         ComplianceItemAudit[]
  businessProfile   BusinessProfile       @relation(fields: [businessProfileId], references: [id], onDelete: Cascade)
  category          ComplianceCategory    @relation(fields: [categoryId], references: [id])
  rule              ComplianceRule        @relation(fields: [ruleId], references: [id])

  @@map("compliance_items")
}

model ComplianceItemAudit {
  id               String         @id @default(uuid()) @db.Uuid
  complianceItemId String         @map("compliance_item_id") @db.Uuid
  oldStatus        String?        @map("old_status") @db.VarChar(20)
  newStatus        String         @map("new_status") @db.VarChar(20)
  notes            String?
  changedBy        String         @map("changed_by") @db.Uuid
  changedAt        DateTime       @default(now()) @map("changed_at")
  user             User           @relation(fields: [changedBy], references: [id])
  complianceItem   ComplianceItem @relation(fields: [complianceItemId], references: [id], onDelete: Cascade)

  @@map("compliance_item_audit")
}

model ComplianceScoreHistory {
  id                String          @id @default(uuid()) @db.Uuid
  businessProfileId String          @map("business_profile_id") @db.Uuid
  overallScore      Decimal         @map("overall_score") @db.Decimal(5, 1)
  categoryScores    Json            @map("category_scores")
  totalItems        Int             @map("total_items")
  completedItems    Int             @map("completed_items")
  criticalPending   Int             @map("critical_pending")
  calculatedAt      DateTime        @default(now()) @map("calculated_at")
  businessProfile   BusinessProfile @relation(fields: [businessProfileId], references: [id], onDelete: Cascade)

  @@map("compliance_score_history")
}

model Conversation {
  id                String           @id @default(uuid()) @db.Uuid
  userId            String           @map("user_id") @db.Uuid
  businessProfileId String?          @map("business_profile_id") @db.Uuid
  title             String?          @db.VarChar(100)
  createdAt         DateTime         @default(now()) @map("created_at")
  updatedAt         DateTime         @default(now()) @updatedAt @map("updated_at")
  model             String?          @db.VarChar(50)
  provider          String?          @db.VarChar(20)
  businessProfile   BusinessProfile? @relation(fields: [businessProfileId], references: [id])
  user              User             @relation(fields: [userId], references: [id], onDelete: Cascade)
  messages          Message[]

  @@map("conversations")
}

model Message {
  id              String       @id @default(uuid()) @db.Uuid
  conversationId  String       @map("conversation_id") @db.Uuid
  role            String       @db.VarChar(20)
  content         String
  sources         Json?
  feedback        String?      @db.VarChar(10)
  feedbackComment String?      @map("feedback_comment")
  tokensUsed      Int?         @map("tokens_used")
  createdAt       DateTime     @default(now()) @map("created_at")
  model           String?      @db.VarChar(50)
  provider        String?      @db.VarChar(20)
  conversation    Conversation @relation(fields: [conversationId], references: [id], onDelete: Cascade)

  @@map("messages")
}

model Regulation {
  id               String            @id @default(uuid()) @db.Uuid
  title            String            @db.VarChar(500)
  regulationNumber String            @map("regulation_number") @db.VarChar(100)
  type             String            @db.VarChar(20)
  issuedBy         String            @map("issued_by") @db.VarChar(200)
  issuedDate       DateTime          @map("issued_date") @db.Date
  effectiveDate    DateTime          @map("effective_date") @db.Date
  status           String            @db.VarChar(20)
  sectorTags       Json              @map("sector_tags")
  sourceUrl        String            @map("source_url") @db.VarChar(500)
  contentRaw       String            @map("content_raw")
  pineconeIndexed  Boolean           @default(false) @map("pinecone_indexed")
  chunkCount       Int?              @default(0) @map("chunk_count")
  createdAt        DateTime          @default(now()) @map("created_at")
  updatedAt        DateTime          @default(now()) @updatedAt @map("updated_at")
  notifications    Notification[]
  chunks           RegulationChunk[]

  @@map("regulations")
}

model RegulationChunk {
  id           String     @id @default(uuid()) @db.Uuid
  regulationId String     @map("regulation_id") @db.Uuid
  chunkIndex   Int        @map("chunk_index")
  content      String
  metadata     Json?
  pineconeId   String?    @map("pinecone_id") @db.VarChar(100)
  createdAt    DateTime   @default(now()) @map("created_at")
  regulation   Regulation @relation(fields: [regulationId], references: [id], onDelete: Cascade)

  @@map("regulation_chunks")
}

model DocumentTemplate {
  id                 String              @id @default(uuid()) @db.Uuid
  name               String              @db.VarChar(200)
  description        String
  category           String              @db.VarChar(50)
  templateHtml       String              @map("template_html")
  formSchema         Json                @map("form_schema")
  isPublished        Boolean             @default(false) @map("is_published")
  version            Int                 @default(1)
  reviewedBy         String?             @map("reviewed_by") @db.Uuid
  createdAt          DateTime            @default(now()) @map("created_at")
  updatedAt          DateTime            @default(now()) @updatedAt @map("updated_at")
  generatedDocuments GeneratedDocument[]

  @@map("document_templates")
}

model GeneratedDocument {
  id                String           @id @default(uuid()) @db.Uuid
  userId            String           @map("user_id") @db.Uuid
  templateId        String           @map("template_id") @db.Uuid
  businessProfileId String           @map("business_profile_id") @db.Uuid
  formData          Json             @map("form_data")
  outputFormat      Json             @map("output_format")
  fileUrlDocx       String?          @map("file_url_docx") @db.VarChar(500)
  fileUrlPdf        String?          @map("file_url_pdf") @db.VarChar(500)
  generatedAt       DateTime         @default(now()) @map("generated_at")
  expiresAt         DateTime         @map("expires_at")
  businessProfile   BusinessProfile  @relation(fields: [businessProfileId], references: [id])
  template          DocumentTemplate @relation(fields: [templateId], references: [id])
  user              User             @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@map("generated_documents")
}

model Notification {
  id           String      @id @default(uuid()) @db.Uuid
  userId       String      @map("user_id") @db.Uuid
  type         String      @db.VarChar(30)
  title        String      @db.VarChar(300)
  body         String
  regulationId String?     @map("regulation_id") @db.Uuid
  isRead       Boolean     @default(false) @map("is_read")
  actionUrl    String?     @map("action_url") @db.VarChar(500)
  createdAt    DateTime    @default(now()) @map("created_at")
  regulation   Regulation? @relation(fields: [regulationId], references: [id])
  user         User        @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@map("notifications")
}

model Subscription {
  id                     String    @id @default(uuid()) @db.Uuid
  userId                 String    @unique @map("user_id") @db.Uuid
  plan                   String    @db.VarChar(20)
  billingCycle           String    @map("billing_cycle") @db.VarChar(10)
  status                 String    @db.VarChar(20)
  currentPeriodStart     DateTime  @map("current_period_start")
  currentPeriodEnd       DateTime  @map("current_period_end")
  cancelAtPeriodEnd      Boolean   @default(false) @map("cancel_at_period_end")
  midtransSubscriptionId String?   @map("midtrans_subscription_id") @db.VarChar(100)
  createdAt              DateTime  @default(now()) @map("created_at")
  updatedAt              DateTime  @default(now()) @updatedAt @map("updated_at")
  invoices               Invoice[]
  user                   User      @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@map("subscriptions")
}

model Invoice {
  id                    String       @id @default(uuid()) @db.Uuid
  userId                String       @map("user_id") @db.Uuid
  subscriptionId        String       @map("subscription_id") @db.Uuid
  amount                Decimal      @db.Decimal(12, 2)
  status                String       @db.VarChar(20)
  midtransTransactionId String?      @map("midtrans_transaction_id") @db.VarChar(100)
  paidAt                DateTime?    @map("paid_at")
  pdfUrl                String?      @map("pdf_url") @db.VarChar(500)
  createdAt             DateTime     @default(now()) @map("created_at")
  subscription          Subscription @relation(fields: [subscriptionId], references: [id])
  user                  User         @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@map("invoices")
}

model ArticleCategory {
  id        String    @id @default(uuid()) @db.Uuid
  name      String    @db.VarChar(100)
  slug      String    @unique @db.VarChar(100)
  sortOrder Int       @default(0) @map("sort_order")
  createdAt DateTime  @default(now()) @map("created_at")
  articles  Article[]

  @@map("article_categories")
}

model Article {
  id              String          @id @default(uuid()) @db.Uuid
  title           String          @db.VarChar(300)
  slug            String          @unique @db.VarChar(300)
  body            String
  categoryId      String          @map("category_id") @db.Uuid
  tags            Json?
  metaDescription String          @map("meta_description") @db.VarChar(160)
  readTimeMinutes Int?            @map("read_time_minutes")
  isPublished     Boolean         @default(false) @map("is_published")
  publishedAt     DateTime?       @map("published_at")
  author          String          @db.VarChar(100)
  createdAt       DateTime        @default(now()) @map("created_at")
  updatedAt       DateTime        @default(now()) @updatedAt @map("updated_at")
  category        ArticleCategory @relation(fields: [categoryId], references: [id])

  @@map("articles")
}

model HrBpjsRate {
  id            String   @id @default(uuid()) @db.Uuid
  component     String   @db.VarChar(50)
  employerRate  Decimal  @map("employer_rate") @db.Decimal(5, 2)
  employeeRate  Decimal  @map("employee_rate") @db.Decimal(5, 2)
  effectiveFrom DateTime @map("effective_from") @db.Date
  createdAt     DateTime @default(now()) @map("created_at")

  @@map("hr_bpjs_rates")
}

model FeatureFlag {
  id          String   @id @default(uuid()) @db.Uuid
  key         String   @unique @db.VarChar(100)
  enabled     Boolean  @default(false)
  targetPlans Json?    @map("target_plans")
  targetUsers Json?    @map("target_users")
  createdAt   DateTime @default(now()) @map("created_at")
  updatedAt   DateTime @default(now()) @updatedAt @map("updated_at")

  @@map("feature_flags")
}

model DocumentReview {
  id             String   @id @default(uuid()) @db.Uuid
  userId         String   @map("user_id") @db.Uuid
  fileName       String   @map("file_name") @db.VarChar(500)
  fileUrl        String?  @map("file_url") @db.VarChar(500)
  fileSize       Int      @map("file_size")
  status         String   @default("pending") @db.VarChar(20)
  riskScore      Int?     @map("risk_score")
  extractedText  String?  @map("extracted_text")
  analysisResult Json?    @map("analysis_result")
  errorMessage   String?  @map("error_message")
  createdAt      DateTime @default(now()) @map("created_at")
  updatedAt      DateTime @default(now()) @updatedAt @map("updated_at")
  user           User     @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@map("document_reviews")
}

model Team {
  id          String           @id @default(uuid()) @db.Uuid
  name        String           @db.VarChar(150)
  ownerId     String           @map("owner_id") @db.Uuid
  createdAt   DateTime         @default(now()) @map("created_at")
  updatedAt   DateTime         @default(now()) @updatedAt @map("updated_at")
  invitations TeamInvitation[]
  members     TeamMember[]
  owner       User             @relation("TeamOwner", fields: [ownerId], references: [id])

  @@map("teams")
}

model TeamMember {
  id        String   @id @default(uuid()) @db.Uuid
  teamId    String   @map("team_id") @db.Uuid
  userId    String   @map("user_id") @db.Uuid
  role      String   @default("member") @db.VarChar(20)
  createdAt DateTime @default(now()) @map("created_at")
  updatedAt DateTime @default(now()) @updatedAt @map("updated_at")
  team      Team     @relation(fields: [teamId], references: [id], onDelete: Cascade)
  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([teamId, userId])
  @@map("team_members")
}

model TeamInvitation {
  id        String   @id @default(uuid()) @db.Uuid
  teamId    String   @map("team_id") @db.Uuid
  email     String   @db.VarChar(255)
  role      String   @default("member") @db.VarChar(20)
  token     String   @unique @db.VarChar(100)
  status    String   @default("pending") @db.VarChar(20)
  expiresAt DateTime @map("expires_at")
  invitedBy String   @map("invited_by") @db.Uuid
  createdAt DateTime @default(now()) @map("created_at")
  inviter   User     @relation("TeamInviter", fields: [invitedBy], references: [id])
  team      Team     @relation(fields: [teamId], references: [id], onDelete: Cascade)

  @@map("team_invitations")
}

model RegulationSyncLog {
  id           String    @id @default(uuid()) @db.Uuid
  source       String    @db.VarChar(50)
  status       String    @db.VarChar(20)
  totalFetched Int       @default(0) @map("total_fetched")
  totalNew     Int       @default(0) @map("total_new")
  totalUpdated Int       @default(0) @map("total_updated")
  totalSkipped Int       @default(0) @map("total_skipped")
  errorMessage String?   @map("error_message")
  triggeredBy  String    @map("triggered_by") @db.VarChar(50)
  startedAt    DateTime  @default(now()) @map("started_at")
  completedAt  DateTime? @map("completed_at")

  @@map("regulation_sync_logs")
}

model CmsPage {
  id              String       @id @default(uuid()) @db.Uuid
  slug            String       @unique @db.VarChar(100)
  title           String       @db.VarChar(200)
  metaDescription String?      @map("meta_description") @db.VarChar(300)
  isPublished     Boolean      @default(false) @map("is_published")
  createdAt       DateTime     @default(now()) @map("created_at")
  updatedAt       DateTime     @default(now()) @updatedAt @map("updated_at")
  sections        CmsSection[]

  @@map("cms_pages")
}

model CmsSection {
  id        String   @id @default(uuid()) @db.Uuid
  pageId    String   @map("page_id") @db.Uuid
  type      String   @db.VarChar(50)
  sortOrder Int      @default(0) @map("sort_order")
  content   Json
  isActive  Boolean  @default(true) @map("is_active")
  createdAt DateTime @default(now()) @map("created_at")
  updatedAt DateTime @default(now()) @updatedAt @map("updated_at")
  page      CmsPage  @relation(fields: [pageId], references: [id], onDelete: Cascade)

  @@map("cms_sections")
}

model OssRegistration {
  id                String          @id @default(uuid()) @db.Uuid
  businessProfileId String          @unique @map("business_profile_id") @db.Uuid
  status            String          @default("not_started") @db.VarChar(30)
  currentStep       Int             @default(0) @map("current_step")
  nibNumber         String?         @map("nib_number") @db.VarChar(50)
  nibIssuedDate     DateTime?       @map("nib_issued_date") @db.Date
  ossRbaStatus      String?         @map("oss_rba_status") @db.VarChar(30)
  notes             String?
  completedAt       DateTime?       @map("completed_at")
  createdAt         DateTime        @default(now()) @map("created_at")
  updatedAt         DateTime        @default(now()) @updatedAt @map("updated_at")
  complianceScore   Int             @default(0) @map("compliance_score")
  skNumber          String?         @map("sk_number") @db.VarChar(100)
  businessProfile   BusinessProfile @relation(fields: [businessProfileId], references: [id], onDelete: Cascade)
  steps             OssStep[]

  @@map("oss_registrations")
}

model OssStep {
  id               String          @id @default(uuid()) @db.Uuid
  registrationId   String          @map("registration_id") @db.Uuid
  stepNumber       Int             @map("step_number")
  title            String          @db.VarChar(200)
  description      String
  status           String          @default("pending") @db.VarChar(20)
  evidenceUrl      String?         @map("evidence_url") @db.VarChar(500)
  evidenceFileName String?         @map("evidence_file_name") @db.VarChar(300)
  notes            String?
  completedAt      DateTime?       @map("completed_at")
  createdAt        DateTime        @default(now()) @map("created_at")
  updatedAt        DateTime        @default(now()) @updatedAt @map("updated_at")
  category         String          @default("dokumen") @db.VarChar(30)
  currentPeriod    String?         @map("current_period") @db.VarChar(20)
  deadlineDay      Int?            @map("deadline_day")
  deadlineMonth    Int?            @map("deadline_month")
  isRecurring      Boolean         @default(false) @map("is_recurring")
  registration     OssRegistration @relation(fields: [registrationId], references: [id], onDelete: Cascade)

  @@unique([registrationId, stepNumber])
  @@map("oss_steps")
}
